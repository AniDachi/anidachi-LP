{
  "name": "anidachi",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "build": "turbo build",
    "build:extension:icons": "node scripts/generate-extension-icons.mjs",
    "build:extension:public": "bash scripts/build-extension-public.sh",
    "build:extension:staging": "bash scripts/build-extension-staging.sh",
    "build:extension:staging:broad": "WXT_BROAD_HOST_PERMISSIONS=true bash scripts/build-extension-staging.sh",
    "check": "turbo check",
    "dev:api": "pnpm --filter @anidachi/api dev",
    "dev:demo": "pnpm --filter @anidachi/demo dev",
    "dev:extension": "pnpm --filter @anidachi/extension dev",
    "dev:web": "pnpm --filter @anidachi/web dev",
    "format": "biome format .",
    "lint": "biome lint .",
    "smoke:worker:staging": "WORKER_HTTP_BASE=https://anidachi-api-staging.vladislav-gul7.workers.dev WORKER_EXPECTED_ENV=staging node scripts/smoke-worker.mjs",
    "test": "turbo test",
    "validate:extension:production": "node scripts/validate-extension-artifact.mjs --channel production --dir anidachi-extension-public",
    "validate:extension:staging": "node scripts/validate-extension-artifact.mjs --channel staging --dir anidachi-extension-staging"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "vitest": "^4.0.15"
  }
}
