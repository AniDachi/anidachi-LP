# Site URL for canonicals, sitemap, robots, Open Graph, and JSON-LD (production: set explicitly)
# NEXT_PUBLIC_SITE_URL=https://www.anidachi.app
# If unset on Vercel, VERCEL_URL is used for previews so sitemap/OG use the deployment host.
#
# Force robots Disallow: / and an empty sitemap (custom staging, or in addition to VERCEL preview):
# NEXT_PUBLIC_ROBOTS_NOINDEX=true
#
# Opt-in: block common AI/training crawlers (GPTBot, Google-Extended, CCBot, anthropic-ai) with Disallow: /
# NEXT_PUBLIC_DISALLOW_AI_TRAINING_BOTS=true

# Optional: Amplitude Unified (Browser SDK: analytics autocapture + session replay; mirrors trackEvent / trackConversion)
# NEXT_PUBLIC_AMPLITUDE_API_KEY=

# Optional: YMYL reviewer strings shown on Blou SEO pages (name, role, credentials)
# NEXT_PUBLIC_MEDICAL_REVIEWER_NAME=
# NEXT_PUBLIC_MEDICAL_REVIEWER_TITLE=
# NEXT_PUBLIC_MEDICAL_REVIEWER_CREDENTIALS=

# Optional: path to default OG image when route-specific opengraph-image is not used
# NEXT_PUBLIC_SEO_OG_IMAGE_PATH=/Anidachi_logo.png

# Stripe Billing.
# Staging/local/preview use Stripe test mode. Production uses Stripe live mode.
# Runtime code fails closed if a live key is configured in a test environment or
# a test key is configured in production.
# STRIPE_SECRET_KEY_TEST=sk_test_...
# STRIPE_SECRET_KEY_LIVE=sk_live_...
#
# Server-side monthly Price IDs. Create/verify prices with:
#   pnpm --filter @anidachi/web stripe:prices:test
#   pnpm --filter @anidachi/web stripe:prices:live
# STRIPE_PRICE_ID_PLUS_TEST=price_...
# STRIPE_PRICE_ID_PLUS_LIVE=price_...
# STRIPE_PRICE_ID_PRO_TEST=price_...
# STRIPE_PRICE_ID_PRO_LIVE=price_...
#
# Stripe webhooks.
# Dashboard → Developers → Webhooks → endpoint:
#   test/staging: https://staging.anidachi.app/api/stripe/webhook
#   live/prod:    https://www.anidachi.app/api/stripe/webhook
# Events: checkout.session.completed, customer.subscription.*, invoice.paid,
# invoice.payment_failed, entitlements.active_entitlement_summary.updated
# STRIPE_WEBHOOK_SECRET_TEST=whsec_...
# STRIPE_WEBHOOK_SECRET_LIVE=whsec_...
# Or register endpoints with:
#   pnpm --filter @anidachi/web stripe:webhook:subscription -- test
#   pnpm --filter @anidachi/web stripe:webhook:subscription -- live
#   (loads keys from your shell env; with .env.local use dotenv-cli or export first)
# SUBSCRIPTION_NOTIFY_EMAILS=you@example.com,ops@example.com
# (Connect Gmail on Kreatli CRM + GOOGLE_* below; production should set GOOGLE_GMAIL_REDIRECT_URI if the app URL differs.)
#
# Optional readable client hints only. Checkout must use server-side Price IDs.
# NEXT_PUBLIC_STRIPE_PRICE_ID_PLUS=
# NEXT_PUBLIC_STRIPE_PRICE_ID_PRO=

# ─── AniDachi user auth ────────────────────────────────────────────────────────
# Discord OAuth — create at https://discord.com/developers/applications
# Redirect URI to add: https://www.anidachi.app/api/auth/callback/discord
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# Optional override (auto-derived from origin in dev):
# DISCORD_REDIRECT_URI=

# Google OAuth for AniDachi sign-in — create a separate OAuth 2.0 client at
# https://console.cloud.google.com (distinct from the Gmail OAuth client below)
# Authorized redirect URI: https://www.anidachi.app/api/auth/callback/google
# ANIDACHI_GOOGLE_CLIENT_ID=
# ANIDACHI_GOOGLE_CLIENT_SECRET=
# Optional override:
# GOOGLE_ANIDACHI_REDIRECT_URI=

# JWT signing — generate a long random string (e.g. openssl rand -hex 64)
# Used for access_token and room_token JWTs
# ANIDACHI_JWT_SECRET=

# Supabase project — users, refresh_tokens, rooms, room_members
# Run supabase/migrations/20260525_anidachi_auth.sql against your project first
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Optional staging-only access gate.
# Never enable this in Production. The middleware ignores it when VERCEL_ENV=production.
# Recommended: set only as branch-scoped Vercel Preview env for the staging branch/PR.
# ANIDACHI_STAGING_GATE_ENABLED=true
# ANIDACHI_STAGING_GATE_PASSWORD_SHA256= # sha256 hex of the shared staging password
# ANIDACHI_STAGING_GATE_COOKIE_SECRET=    # random long secret for signed remember-cookie
# ANIDACHI_STAGING_GATE_COOKIE_MAX_AGE_SECONDS=2592000
# ───────────────────────────────────────────────────────────────────────────────

# Kreatli Email CRM + Bloü (same login cookie; production: set both; dev uses safe fallbacks only in NODE_ENV=development)
KREATLI_CRM_PASSWORD=
KREATLI_CRM_SESSION_SECRET=

# Optional: absolute path to CRM data (defaults to ./crm-data). Same for Next app and `npm run crm`.
# CRM_DATA_DIR=

# Gmail send (Kreatli CRM) — create OAuth "Web application" in Google Cloud Console
# Authorized redirect URI must match exactly the URL you use in the browser, e.g.
#   http://localhost:3003/api/kreatli-crm/gmail/callback   (default dev port in package.json)
# Only set this if the app cannot infer the public URL (reverse proxy / custom host):
# GOOGLE_GMAIL_REDIRECT_URI=http://localhost:3003/api/kreatli-crm/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Production persistence (Vercel/serverless): filesystem is read-only, so Gmail tokens must be stored in Vercel Blob.
# Set BLOB_READ_WRITE_TOKEN in your deployment environment (same token used by /api/blou/upload).
# Optional: BLOB_ACCESS=private (default) or public
# BLOB_READ_WRITE_TOKEN=
# Sender name recipients see. Gmail ignores MIME "From" names for API mail — we update your Gmail
# "Send mail as" display name via the Settings API (needs extra OAuth scope). After upgrading CRM:
# disconnect Gmail on the CRM page → Connect again → add gmail.settings.basic on Google’s consent screen if asked.
# Set on every deployed host (e.g. Vercel) if you rely on API sync; restart after changes.
# GOOGLE_GMAIL_SENDER_NAME=Heorhi Talochka
# Optional: send as this address instead of the OAuth profile email. Must exactly match a row under
# Gmail → Settings → Accounts → Send mail as (wrong value = wrong or missing display name for recipients).
# GOOGLE_GMAIL_FROM_EMAIL=you@yourdomain.com

# Google Ads API (Keyword Planner) — uses OAuth scope https://www.googleapis.com/auth/adwords
# Reuses ANIDACHI_GOOGLE_CLIENT_ID/SECRET by default, or set GOOGLE_ADS_CLIENT_ID/SECRET.
# Add redirect URI to the same OAuth client (or a dedicated one):
#   http://localhost:3003/api/google-ads/oauth/callback
#   https://www.anidachi.app/api/google-ads/oauth/callback
# Also add the adwords scope on Google Cloud → OAuth consent screen → Data Access.
# GOOGLE_ADS_DEVELOPER_TOKEN=
# GOOGLE_ADS_CUSTOMER_ID=5723352650
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=   # only if querying via a Manager (MCC) account
# GOOGLE_ADS_REFRESH_TOKEN=       # optional if you connect via /api/google-ads/oauth/connect
# GOOGLE_ADS_REDIRECT_URI=        # optional override
