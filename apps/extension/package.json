{
  "name": "@anidachi/extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "wxt build",
    "check": "wxt prepare && tsc -p tsconfig.json",
    "dev": "wxt",
    "dev:local": "wxt",
    "dev:staging": "WXT_EXTENSION_CHANNEL=staging WXT_WEB_HTTP_BASE=https://staging.anidachi.app WXT_API_HTTP_BASE=https://anidachi-api-staging.vladislav-gul7.workers.dev WXT_API_WS_BASE=wss://anidachi-api-staging.vladislav-gul7.workers.dev WXT_BROAD_HOST_PERMISSIONS=true wxt",
    "dev:staging:narrow": "WXT_EXTENSION_CHANNEL=staging WXT_WEB_HTTP_BASE=https://staging.anidachi.app WXT_API_HTTP_BASE=https://anidachi-api-staging.vladislav-gul7.workers.dev WXT_API_WS_BASE=wss://anidachi-api-staging.vladislav-gul7.workers.dev WXT_BROAD_HOST_PERMISSIONS=false wxt",
    "test": "wxt prepare && vitest run"
  },
  "dependencies": {
    "@anidachi/protocol": "workspace:*",
    "lucide-react": "^0.555.0",
    "motion": "^12.40.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.34",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.0.10",
    "typescript": "^6.0.3",
    "vitest": "^4.0.15",
    "wxt": "^0.20.26"
  }
}
